{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/splash/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "",
        "disableScroll": true
      }
    },
    {
      "path": "pages/home/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/quick-entries/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages/login",
      "name": "auth-login",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "登录",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        },
        {
          "path": "profile",
          "style": {
            "navigationBarTitleText": "完善资料",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "pages/qrcode-login",
      "name": "auth-qrcode",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "扫码登录",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "pages/agreement",
      "name": "agreement",
      "pages": [
        {
          "path": "user",
          "style": {
            "navigationBarTitleText": "用户协议",
            "navigationStyle": "custom",
            "disableScroll": false
          }
        },
        {
          "path": "privacy",
          "style": {
            "navigationBarTitleText": "隐私政策",
            "navigationStyle": "custom",
            "disableScroll": false
          }
        }
      ]
    },
    {
      "root": "pages/mine/power",
      "name": "mine-power",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "我的算力",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        },
        {
          "path": "detail",
          "style": {
            "navigationBarTitleText": "算力明细",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        },
        {
          "path": "recharge",
          "style": {
            "navigationBarTitleText": "充值算力",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "pages/mine/referral",
      "name": "mine-referral",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "我要推荐",
            "navigationStyle": "custom",
            "disableScroll": false
          }
        }
      ]
    },
    {
      "root": "pages/mine/contact",
      "name": "mine-contact",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "联系客服",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "pages/mine/creation-records",
      "name": "mine-creation-records",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "我的创作记录",
            "enablePullDownRefresh": false,
            "backgroundTextStyle": "dark"
          }
        }
      ]
    },
    {
      "root": "pages/mine/membership",
      "name": "mine-membership",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "开通会员",
            "navigationStyle": "custom",
            "disableScroll": false
          }
        }
      ]
    },
    {
      "root": "pages/aichat",
      "name": "aichat",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "对话",
            "navigationStyle": "custom",
            "disableScroll": true
          }
        }
      ]
    },
    {
      "root": "pages/common",
      "name": "common",
      "pages": [
        {
          "path": "webview",
          "style": {
            "navigationBarTitleText": "页面",
            "navigationStyle": "default"
          }
        }
      ]
    }
  ],
  "preloadRule": {
    "pages/home/index": {
      "network": "all",
      "packages": ["common", "aichat"]
    },
    "pages/mine/index": {
      "network": "all",
      "packages": [
        "mine-power",
        "mine-referral",
        "mine-contact",
        "mine-creation-records",
        "mine-membership",
        "auth-login"
      ]
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "dingma",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F7FA"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#3B82F6",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "static/tab/sfire.png",
        "selectedIconPath": "static/tab/sfire-active.png"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "static/tab/mine.png",
        "selectedIconPath": "static/tab/mine-active.png"
      }
    ]
  }
}
