    "pages/index/index": {
      "network": "all",
      "packages": ["article", "agent", "copywriting", "tools"]
    },
    "pages/project/index": {
      "network": "all",
      "packages": [
        "project-create",
        "project-report",
        "conversation",
        "aichat"
      ]
    },
    "pages/mine/index": {
      "network": "all",
      "packages": [
        "mine-power",
        "mine-referral",
        "mine-contact",
        "mine-membership",
        "auth-login"
      ]
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "dingma",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F7FA"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#F37021",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "发现",
        "iconPath": "static/tab/home.png",
        "selectedIconPath": "static/tab/home-active.png"
      },
      {
        "pagePath": "pages/project/index",
        "text": "IP操作台",
        "iconPath": "static/tab/sfire.png",
        "selectedIconPath": "static/tab/sfire-active.png"
